# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# uploads (dev local storage) - keep sample/ (used by prisma seed)
/public/uploads/*
!/public/uploads/.gitkeep
!/public/uploads/sample/

# vercel
.vercel

# claude code local state
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts
