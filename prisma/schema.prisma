generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum ResourceType {
  PDF
  IMAGE
  VIDEO
  OTHER
  SLIDES
}

enum QuizScope {
  LESSON
  MODULE
  COURSE
}

enum LessonType {
  VIDEO
  TEXT
}

enum ReactionType {
  LIKE
  DISLIKE
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           Role            @default(STUDENT)
  bio            String?
  websiteUrl     String?
  twitterUrl     String?
  linkedinUrl    String?
  youtubeUrl     String?
  instagramUrl   String?
  facebookUrl    String?
  tiktokUrl      String?
  githubUrl      String?
  discordUrl     String?
  mediumUrl      String?
  twitchUrl      String?
  certifications Certification[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  accounts             Account[]
  sessions             Session[]
  coursesTaught        Course[]         @relation("InstructorCourses")
  collaboratingCourses Course[]         @relation("CourseCollaborators")
  lessonContributions  Lesson[]         @relation("LessonContributors")
  bundles              Bundle[]
  cartItems            CartItem[]
  enrollments          Enrollment[]
  lessonProgress       LessonProgress[]
  quizAttempts         QuizAttempt[]
  reviews              Review[]
  lessonComments       LessonComment[]
  commentLikes         CommentLike[]
  lessonReactions      LessonReaction[]
  watchEvents          WatchEvent[]
}

model Certification {
  id        String   @id @default(cuid())
  name      String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CartItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model Bundle {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructorId String
  instructor   User   @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  courses Course[]

  @@index([instructorId])
}

model Course {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  description      String
  thumbnailUrl     String?
  trailerUrl       String?
  category         String
  level            String   @default("beginner")
  published        Boolean  @default(false)
  price            Float    @default(0)
  originalPrice    Float?
  rating           Float    @default(4.5)
  ratingCount      Int      @default(0)
  learningOutcomes String[] @default([])
  requirements     String[] @default([])
  targetAudience   String[] @default([])
  topics           String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  instructorId String
  instructor   User   @relation("InstructorCourses", fields: [instructorId], references: [id], onDelete: Cascade)

  collaborators User[] @relation("CourseCollaborators")

  bundleId String?
  bundle   Bundle? @relation(fields: [bundleId], references: [id], onDelete: SetNull)

  modules     Module[]
  enrollments Enrollment[]
  cartItems   CartItem[]
  quiz        Quiz?
  reviews     Review[]

  @@index([instructorId])
  @@index([published])
  @@index([bundleId])
}

model Module {
  id    String @id @default(cuid())
  title String
  order Int

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  lessons Lesson[]
  quizzes Quiz[]

  @@index([courseId])
}

model Lesson {
  id              String     @id @default(cuid())
  title           String
  order           Int
  isFreePreview   Boolean    @default(false)
  type            LessonType @default(VIDEO)
  contentUrl      String?
  // Master playlist HLS (.m3u8) — atualizado pelo worker à medida que cada
  // rendition fica pronta (ver lib/videoTranscode.ts, worker/index.js). Só
  // referencia as variantes já concluídas, por isso fica reproduzível assim
  // que a 1ª existe, mesmo com o job ainda PROCESSING.
  hlsMasterUrl    String?
  thumbnailUrl    String?
  // Legendas WebVTT geradas no browser do instrutor no momento do upload
  // (transformers.js/Whisper, client-side — sem custo de API nem carga
  // extra no worker do Railway, ver lib/captions.ts). Ficheiro pequeno,
  // sobe pelo /api/upload normal (não precisa do worker nem de chunking).
  captionsUrl     String?
  textContent     String?
  durationSeconds Int?
  description     String?

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  contributors User[] @relation("LessonContributors")

  resources   LessonResource[]
  progress    LessonProgress[]
  comments    LessonComment[]
  reactions   LessonReaction[]
  quiz        Quiz?
  viewCount   Int              @default(0)
  createdAt   DateTime         @default(now())
  watchEvents WatchEvent[]

  videoRenditions LessonVideoRendition[]
  transcodeJobs   VideoTranscodeJob[]

  @@index([moduleId])
}

model LessonComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId String?
  parent   LessonComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  LessonComment[] @relation("CommentReplies")

  likes CommentLike[]

  @@index([lessonId])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  commentId String
  comment   LessonComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model LessonReaction {
  id        String       @id @default(cuid())
  type      ReactionType
  createdAt DateTime     @default(now())

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model LessonResource {
  id        String       @id @default(cuid())
  name      String
  url       String
  type      ResourceType
  sizeBytes Int
  createdAt DateTime     @default(now())

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

enum TranscodeStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// Fila para o worker externo (ffmpeg, fora do Next.js/Vercel — sem binário
// ffmpeg nem tempo de execução para isso nas functions serverless). O
// worker faz poll de PENDING, marca PROCESSING, sobe as renditions e chama
// de volta a completar/falhar (ver app/api/worker/jobs).
model VideoTranscodeJob {
  id        String          @id @default(cuid())
  sourceUrl String
  status    TranscodeStatus @default(PENDING)
  error     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([lessonId])
}

// Uma linha por resolução gerada pelo worker para uma aula. "quality" é o
// rótulo mostrado no seletor do player (ex. "1080p").
model LessonVideoRendition {
  id        String   @id @default(cuid())
  quality   String
  url       String
  width     Int
  height    Int
  sizeBytes Int
  createdAt DateTime @default(now())

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, quality])
  @@index([lessonId])
}

model Enrollment {
  id         String   @id @default(cuid())
  enrolledAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model LessonProgress {
  id             String    @id @default(cuid())
  completed      Boolean   @default(false)
  completedAt    DateTime?
  watchedSeconds Int       @default(0)
  updatedAt      DateTime  @updatedAt

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

// Um ping por cada 5s de reprodução (ver /api/progress) — usado só para
// distribuição por hora do dia ("quando é que as pessoas veem aulas").
// Tempo total por aula/curso continua a vir de LessonProgress.watchedSeconds.
model WatchEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([createdAt])
}

model Quiz {
  id               String    @id @default(cuid())
  scope            QuizScope
  title            String
  // Só usado em scope MODULE — posição entre as aulas do mesmo módulo (vários
  // quizzes por módulo, cada um na sua posição, tal como uma aula).
  order            Int       @default(0)
  maxAttempts      Int?
  timeLimitMinutes Int?
  createdAt        DateTime  @default(now())

  lessonId String? @unique
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  // Sem @unique: um módulo pode ter vários quizzes (ordenados por `order`,
  // intercalados com as aulas), ao contrário do quiz de aula/curso (1:1).
  moduleId String?
  module   Module? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  courseId String? @unique
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([moduleId])
}

model QuizQuestion {
  id    String @id @default(cuid())
  text  String
  order Int

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  options QuizOption[]

  @@index([quizId])
}

model QuizOption {
  id        String  @id @default(cuid())
  text      String
  isCorrect Boolean @default(false)
  order     Int

  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model QuizAttempt {
  id           String   @id @default(cuid())
  scorePercent Int
  answers      Json
  createdAt    DateTime @default(now())

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId, userId])
}
