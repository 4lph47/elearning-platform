generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum ResourceType {
  PDF
  IMAGE
  VIDEO
  OTHER
  SLIDES
}

enum QuizScope {
  LESSON
  MODULE
  COURSE
}

enum LessonType {
  VIDEO
  TEXT
}

enum ReactionType {
  LIKE
  DISLIKE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  coursesTaught        Course[]         @relation("InstructorCourses")
  collaboratingCourses Course[]         @relation("CourseCollaborators")
  lessonContributions  Lesson[]         @relation("LessonContributors")
  bundles              Bundle[]
  cartItems            CartItem[]
  enrollments          Enrollment[]
  lessonProgress       LessonProgress[]
  quizAttempts         QuizAttempt[]
  reviews              Review[]
  lessonComments       LessonComment[]
  commentLikes         CommentLike[]
  lessonReactions      LessonReaction[]
}

model CartItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model Bundle {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instructorId String
  instructor   User   @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  courses Course[]

  @@index([instructorId])
}

model Course {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  thumbnailUrl String?
  trailerUrl   String?
  category     String
  level        String   @default("beginner")
  published    Boolean  @default(false)
  price        Float    @default(0)
  originalPrice Float?
  rating       Float    @default(4.5)
  ratingCount  Int      @default(0)
  learningOutcomes String[] @default([])
  requirements     String[] @default([])
  targetAudience   String[] @default([])
  topics           String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instructorId String
  instructor   User   @relation("InstructorCourses", fields: [instructorId], references: [id], onDelete: Cascade)

  collaborators User[] @relation("CourseCollaborators")

  bundleId String?
  bundle   Bundle? @relation(fields: [bundleId], references: [id], onDelete: SetNull)

  modules     Module[]
  enrollments Enrollment[]
  cartItems   CartItem[]
  quiz        Quiz?
  reviews     Review[]

  @@index([instructorId])
  @@index([published])
  @@index([bundleId])
}

model Module {
  id    String @id @default(cuid())
  title String
  order Int

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  lessons Lesson[]
  quiz    Quiz?

  @@index([courseId])
}

model Lesson {
  id              String     @id @default(cuid())
  title           String
  order           Int
  isFreePreview   Boolean    @default(false)
  type            LessonType @default(VIDEO)
  contentUrl      String?
  textContent     String?
  durationSeconds Int?
  description     String?

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  contributors User[] @relation("LessonContributors")

  resources LessonResource[]
  progress  LessonProgress[]
  comments  LessonComment[]
  reactions LessonReaction[]
  quiz      Quiz?
  viewCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([moduleId])
}

model LessonComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId String?
  parent   LessonComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  LessonComment[] @relation("CommentReplies")

  likes CommentLike[]

  @@index([lessonId])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  commentId String
  comment   LessonComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model LessonReaction {
  id        String       @id @default(cuid())
  type      ReactionType
  createdAt DateTime     @default(now())

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model LessonResource {
  id        String       @id @default(cuid())
  name      String
  url       String
  type      ResourceType
  sizeBytes Int
  createdAt DateTime     @default(now())

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Enrollment {
  id          String   @id @default(cuid())
  enrolledAt  DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model LessonProgress {
  id             String    @id @default(cuid())
  completed      Boolean   @default(false)
  completedAt    DateTime?
  watchedSeconds Int       @default(0)
  updatedAt      DateTime  @updatedAt

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model Quiz {
  id               String    @id @default(cuid())
  scope            QuizScope
  title            String
  maxAttempts      Int?
  timeLimitMinutes Int?
  createdAt        DateTime  @default(now())

  lessonId String? @unique
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  moduleId String? @unique
  module   Module? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  courseId String? @unique
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id     String @id @default(cuid())
  text   String
  order  Int

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  options QuizOption[]

  @@index([quizId])
}

model QuizOption {
  id        String  @id @default(cuid())
  text      String
  isCorrect Boolean @default(false)
  order     Int

  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model QuizAttempt {
  id           String   @id @default(cuid())
  scorePercent Int
  answers      Json
  createdAt    DateTime @default(now())

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId, userId])
}
