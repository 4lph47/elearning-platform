DATABASE_URL="postgresql://elearning:elearning@localhost:5432/elearning?schema=public"
# In production with Supabase, use the transaction pooler (port 6543, pgbouncer=true&connection_limit=1)
# for DATABASE_URL, and the session pooler or direct connection (port 5432) for DIRECT_URL.
DIRECT_URL="postgresql://elearning:elearning@localhost:5432/elearning?schema=public"
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"
ANTHROPIC_API_KEY="sk-ant-..."

# Supabase Storage (upload de vídeos/ficheiros das aulas)
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SECRET_KEY="sb_secret_..."
SUPABASE_STORAGE_BUCKET="course-media"
# Expostas ao browser de propósito (chave pública, protegida por RLS) — upload
# direto do browser pro Storage (vídeos/documentos), sem passar pelo Vercel.
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Worker de transcoding de vídeo (worker/) — mesmo valor nas duas pontas.
# Gerar com: openssl rand -hex 32
WORKER_API_SECRET="replace-with-a-random-secret"
# URL pública do worker no Railway/Render (upload direto do browser pro
# worker — ver app/api/upload/authorize-direct). Sem barra final.
WORKER_PUBLIC_URL="https://o-teu-worker.up.railway.app"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Email (magic link) provider — SMTP connection string
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@example.com"
